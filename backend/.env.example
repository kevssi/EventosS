# =====================================================
# VARIABLES DE ENTORNO REQUERIDAS
# Copia este archivo como .env para desarrollo local
# En Vercel, configura cada variable en:
# Dashboard → Tu proyecto → Settings → Environment Variables
# =====================================================

# --- BASE DE DATOS MySQL ---
# Opción 1: Connection string completo (recomendado para PlanetScale, Railway, Aiven, etc.)
DATABASE_URL=mysql://usuario:password@host:3306/nombre_db

# Opción 2: Variables individuales (si no usas DATABASE_URL)
# DB_HOST=tu-host.railway.app
# DB_USER=root
# DB_PASSWORD=tu_password
# DB_NAME=eventos
# DB_PORT=3306

# --- AUTENTICACIÓN JWT ---
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga_y_aleatoria

# --- MERCADO PAGO ---
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx-xxxx-xxxx-xxxx
MERCADOPAGO_OAUTH_CLIENT_ID=tu_client_id
MERCADOPAGO_OAUTH_CLIENT_SECRET=tu_client_secret

# URL pública del backend (para back_urls de Mercado Pago)
# En Vercel será algo como: https://tu-proyecto.vercel.app
APP_BASE_URL=https://tu-proyecto.vercel.app

# --- CLOUDINARY (para subir imágenes de eventos) ---
# Opción 1: Connection string (CLOUDINARY_URL tiene precedencia)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Opción 2: Variables individuales
# CLOUDINARY_CLOUD_NAME=tu_cloud_name
# CLOUDINARY_API_KEY=tu_api_key
# CLOUDINARY_API_SECRET=tu_api_secret
